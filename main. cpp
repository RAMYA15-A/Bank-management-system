// write new account to file

void writeAccount() {

BankAccount ac;

ofstream outFile;

outFile.open("account.dat", ios::binary | ios::app);

ac.createAccount();

outFile.write(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

outFile.close();

}
// display account details by account number

void displayAccount(int n) {

BankAccount ac;

bool found = false;

ifstream inFile;

inFile.open("account.dat", ios::binary);

if (!inFile) {

cout << "File could not be opened! Press any key...\n";

return;

}

while (inFile.read(reinterpret_cast<char *>(&ac), sizeof(BankAccount))) {

if (ac.getAccNo() == n) {

ac.showAccount();

found = true;

}

}

inFile.close();

if (!found)

cout << "\n\nAccount number does not exist\n";

}

// modify account

void modifyAccount(int n) {

BankAccount ac;

bool found = false;

fstream File;
File.open("account.dat", ios::binary | ios::in | ios::out);

if (!File) {

cout << "File could not be opened! Press any key...\n";

return;

}

while (!File.eof() && !found) {

int pos = File.tellg();

File.read(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

if (ac.getAccNo() == n) {

ac.showAccount();

cout << "\nEnter New Details:\n";

ac.modify();

File.seekp(pos);

File.write(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

cout << "\n\nRecord Updated Successfully\n";

found = true;

}

}

File.close();

if (!found)

cout << "\n\nRecord Not Found\n";

}

// delete account

void deleteAccount(int n) {

BankAccount ac;
ifstream inFile;

ofstream outFile;

inFile.open("account.dat", ios::binary);

if (!inFile) {

cout << "File could not be opened! Press any key...\n";

return;

}

outFile.open("temp.dat", ios::binary);

while (inFile.read(reinterpret_cast<char *>(&ac), sizeof(BankAccount))) {

if (ac.getAccNo() != n) {

outFile.write(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

}

}

inFile.close();

outFile.close();

remove("account.dat");

rename("temp.dat", "account.dat");

cout << "\n\nRecord Deleted Successfully\n";

}

// display all accounts

void displayAll() {

BankAccount ac;

ifstream inFile;

inFile.open("account.dat", ios::binary);

if (!inFile) {
cout << "File could not be opened! Press any key...\n";

return;

}

cout << "\n\nACCOUNT HOLDER LIST\n";

cout << "====================================================\n";

cout << "A/c no. NAME Type Balance\n";

cout << "====================================================\n";

while (inFile.read(reinterpret_cast<char *>(&ac), sizeof(BankAccount))) {

ac.report();

}

inFile.close();

}

// deposit or withdraw

void depositWithdraw(int n, int opƟon) {

double amt;

bool found = false;

BankAccount ac;

fstream File;

File.open("account.dat", ios::binary | ios::in | ios::out);

if (!File) {

cout << "File could not be opened! Press any key...\n";

return;

}

while (!File.eof() && !found) {

int pos = File.tellg();
File.read(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

if (ac.getAccNo() == n) {

ac.showAccount();

if (opƟon == 1) {

cout << "\nEnter The Amount To Deposit: ";

cin >> amt;

ac.deposit(amt);

}

if (opƟon == 2) {

cout << "\nEnter The Amount To Withdraw: ";

cin >> amt;

double bal = ac.getBalance() - amt;

if ((bal < 0)) {

cout << "Insufficient Balance!\n";

} else {

ac.withdraw(amt);

}

}

File.seekp(pos);

File.write(reinterpret_cast<char *>(&ac), sizeof(BankAccount));

cout << "\n\nRecord Updated Successfully\n";

found = true;

}

}

File.close();
if (!found)

cout << "\n\nRecord Not Found\n";

}